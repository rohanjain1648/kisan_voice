# KisanVoice Environment Variables
# Copy this file to .env and fill in your values

# Required: Groq API Key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Gradio server settings
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=true

# Optional: Whisper model size (tiny/base/small/medium)
# base = ~74MB, good balance of speed and accuracy
WHISPER_MODEL=base
